{
  "manifest_version": 3,
  "name": "Work Timer",
  "version": "1.0.0",
  "description": "Lightweight time tracking Chrome Extension. Track, manage, and analyze your working time directly from the browser.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "idle"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Work Timer"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+O",
        "mac": "Alt+Shift+O"
      }
    },
    "toggle-timer": {
      "suggested_key": {
        "default": "Alt+Shift+Up",
        "mac": "Alt+Shift+Up"
      },
      "description": "Start or stop the timer"
    },
    "toggle-pause": {
      "suggested_key": {
        "default": "Alt+Shift+Down",
        "mac": "Alt+Shift+Down"
      },
      "description": "Pause or resume the timer"
    }
  }
}
